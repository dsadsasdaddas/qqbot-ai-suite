# Google Vertex image proxy
GOOGLE_VERTEX_PROJECT=your-google-cloud-project-id
GOOGLE_VERTEX_LOCATION=global
GOOGLE_VERTEX_MODEL=gemini-2.5-flash-image
GOOGLE_VERTEX_ALLOWED_MODELS=gemini-2.5-flash-image,gemini-3.1-flash-image
GOOGLE_VERTEX_PROXY_PORT=8877
GOOGLE_VERTEX_PROXY_HOST=0.0.0.0
DORA_API_TOKEN=change-me-long-random-token
DORA_REQUIRE_AUTH=true
DORA_RATE_LIMIT_PER_MINUTE=10
DORA_ALLOWED_ORIGINS=*

# Optional HTTP proxy for Google APIs, e.g. mihomo/clash on host
HTTP_PROXY=http://127.0.0.1:7891
HTTPS_PROXY=http://127.0.0.1:7891
ALL_PROXY=http://127.0.0.1:7891
NO_PROXY=localhost,127.0.0.1
NODE_USE_ENV_PROXY=1

# GLM code runner
GLM_CODE_RUNNER_TOKEN=change-me-long-random-token
